{
  "name": "@aia/ca-session-source-client",
  "version": "0.1.0",
  "description": "TypeScript SDK for the ca-session-source HTTP and SSE contracts.",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "engines": {
    "node": "^20.19 || ^22.12 || >=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js",
      "default": "./dist/errors.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "import": "./dist/events.js",
      "default": "./dist/events.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "node --eval \"await import('./dist/index.js')\"",
    "test": "node --experimental-strip-types --test src/**/*.test.ts test/**/*.test.js"
  }
}
